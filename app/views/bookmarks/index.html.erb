<% content_for :title, page_title("ブックマーク一覧") %>

<section class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold leading-snug text-slate-900">ブックマーク一覧</h1>
      <p class="mt-1 text-sm text-slate-500">あとで読みたい投稿をまとめて確認できます。</p>
    </div>
    <%= link_to "投稿一覧に戻る", posts_path, class: "inline-flex items-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50" %>
  </div>

  <% if @posts.any? %>
    <div class="space-y-6">
      <% @posts.each do |post| %>
        <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="flex items-center gap-3">
              <% if post.user&.avatar_or_default %>
                <%= image_tag post.user.avatar_or_default, class: "h-9 w-9 rounded-full object-cover" %>
              <% else %>
                <span class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-400">
                  <i class="fas fa-user text-white"></i>
                </span>
              <% end %>
              <%= link_to(post.user&.name || "削除されたユーザー",
                          post.user ? user_path(post.user) : "#",
                          class: "text-sm font-semibold text-slate-800 hover:text-slate-900") %>
            </div>
            <div class="text-right">
              <h3 class="text-lg font-semibold leading-snug text-slate-900">
                <%= link_to post.title.presence || "無題", post, class: "hover:text-brand-600" %>
              </h3>
              <span class="mt-1 inline-flex items-center gap-1 text-xs text-slate-500">
                <i class="fas fa-calendar-alt"></i>
                <%= post.created_at.strftime("%Y年%m月%d日 %H:%M") %>
              </span>
            </div>
          </div>

          <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            <div>
              <span class="block text-xs font-semibold uppercase tracking-wide text-slate-400">投稿タイプ</span>
              <span class="mt-1 block text-sm text-slate-700">
                <% if post.post_type.present? %>
                  <%= case post.post_type.name
                      when 'knowledge_sharing' then '知識共有'
                      when 'question' then '質問・相談'
                      when 'discussion' then '議論・討論'
                      when 'tutorial' then 'チュートリアル'
                      when 'experience_sharing' then '体験談・事例'
                      when 'news_update' then 'ニュース・更新'
                      when 'opinion' then '意見・考察'
                      else post.post_type.name
                      end %>
                <% else %>
                  <span class="text-slate-400">未設定</span>
                <% end %>
              </span>
            </div>
            <div>
              <span class="block text-xs font-semibold uppercase tracking-wide text-slate-400">カテゴリー</span>
              <span class="mt-1 block text-sm text-slate-700">
                <% if post.category %>
                  <%= link_to post.category.full_name, posts_path(category_id: post.category.id), class: "text-brand-600 hover:text-brand-500" %>
                <% else %>
                  <span class="text-slate-400">未分類</span>
                <% end %>
              </span>
            </div>
            <div>
              <span class="block text-xs font-semibold uppercase tracking-wide text-slate-400">目的</span>
              <span class="mt-1 block text-sm text-slate-700">
                <% if post.purpose.present? %>
                  <%= truncate(post.purpose, length: 80) %>
                <% else %>
                  <span class="text-slate-400">未設定</span>
                <% end %>
              </span>
            </div>
            <div>
              <span class="block text-xs font-semibold uppercase tracking-wide text-slate-400">対象読者</span>
              <span class="mt-1 block text-sm text-slate-700">
                <% if post.target_audience.present? %>
                  <%= truncate(post.target_audience, length: 60) %>
                <% else %>
                  <span class="text-slate-400">未設定</span>
                <% end %>
              </span>
            </div>
          </div>

          <p class="mt-4 text-sm leading-relaxed text-slate-600">
            <%= truncate(strip_tags(post.content_as_html), length: 160) %>
          </p>

          <div class="mt-5 flex flex-wrap items-center justify-between gap-4 border-t border-slate-100 pt-4">
            <div class="flex flex-wrap gap-2">
              <% if post.tags.any? %>
                <% post.tags.limit(3).each do |tag| %>
                  <%= link_to "##{tag.name}", posts_path(tag: tag.name), class: "inline-flex items-center rounded-full border border-slate-200 px-2.5 py-1 text-xs font-semibold text-slate-600 transition hover:border-slate-300 hover:bg-slate-50" %>
                <% end %>
                <% if post.tags.count > 3 %>
                  <span class="inline-flex items-center rounded-full border border-slate-200 px-2.5 py-1 text-xs font-semibold text-slate-400">+<%= post.tags.count - 3 %></span>
                <% end %>
              <% end %>
            </div>

            <div class="flex items-center gap-4 text-sm text-slate-500">
              <span class="inline-flex items-center gap-1">
                <i class="fas fa-heart text-rose-500"></i>
                <span><%= post.likes.count %></span>
              </span>
              <%= render "bookmarks/bookmark_button", post: post, style: :stat %>
              <span class="inline-flex items-center gap-1">
                <i class="fas fa-comment text-sky-500"></i>
                <span><%= post.comments.count %></span>
              </span>
              <%= link_to "続きを読む", post, class: "inline-flex items-center rounded-xl border border-brand-500 bg-transparent px-3 py-1.5 text-xs font-semibold text-brand-600 transition hover:bg-brand-50" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-slate-200 bg-white py-16 text-center shadow-sm">
      <i class="fas fa-bookmark text-4xl text-slate-300"></i>
      <h4 class="mt-4 text-lg font-semibold text-slate-500">ブックマークがまだありません</h4>
      <p class="mt-2 text-sm text-slate-500">気になる投稿のブックマークボタンを押して、あとで読み返しましょう。</p>
      <div class="mt-6">
        <%= link_to "投稿一覧を見る", posts_path, class: "inline-flex items-center rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-500" %>
      </div>
    </div>
  <% end %>
</section>
