
<div class="mt-6 flex flex-wrap justify-center gap-3 text-center">
  <%- if controller_name != 'webauthn_authentications' %>
    <%= link_to "ログイン", new_user_session_path, class: "rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "新規登録", new_user_registration_path, class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800" %>
  <% end %>
</div>